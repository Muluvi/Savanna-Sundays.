
{
  "entities": {
    "InvitedUser": {
      "title": "Invited User",
      "description": "Users who are permitted to view the pitch deck.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the invited stakeholder."
        },
        "name": {
          "type": "string",
          "description": "Name of the stakeholder."
        },
        "invitedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["email"]
    },
    "ProspectusLead": {
      "title": "Prospectus Lead",
      "description": "Stakeholder interest captured from the deck.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "interest": { "type": "string", "enum": ["high", "medium", "low"] },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "AnalyticsEvent": {
      "title": "Analytics Event",
      "description": "Recorded engagement metric.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "sectionId": { "type": "string" },
        "type": { "type": "string", "enum": ["view", "scroll_depth"] },
        "value": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/invitedUsers/{email}": {
      "schema": "InvitedUser",
      "description": "Whitelist of stakeholders allowed to view the deck."
    },
    "/prospectusLeads/{leadId}": {
      "schema": "ProspectusLead",
      "description": "Captured leads from the prospectus footer."
    }
  }
}
